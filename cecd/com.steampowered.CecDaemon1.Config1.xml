<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <!--
      com.steampowered.CecDaemon1.Config1
      @short_description: The configuration of the daemon, for remote querying.

  -->
  <interface name="com.steampowered.CecDaemon1.Config1">
    <!--
        OsdName:

        The configured OSD name. If no OSD name is configured, this value will
		be an empty string.
    -->
    <property name="OsdName" type="s" access="read"/>

    <!--
        VendorId:

        The configured vendor ID. If no vendor ID is configured, this value
        will be negative.
    -->
    <property name="VendorId" type="i" access="read"/>

    <!--
        LogicalAddress:

        The configured logical address type.
    -->
    <property name="LogicalAddress" type="y" access="read"/>

    <!--
        Mappings:

        The configured UI command mappings.
    -->
    <property name="Mappings" type="a(ayq)" access="read"/>

    <!--
        WakeTv:

        If the daemon is configured to wake the TV when this device comes back
		up from suspend.
    -->
    <property name="WakeTv" type="b" access="read"/>

    <!--
        SuspendTv:

        If the daemon is configured to put the TV into standby when this device
		enters suspend.
    -->
    <property name="SuspendTv" type="b" access="read"/>

    <!--
        AllowStandby:

        If the daemon is configured to suspend the device when the TV enters
		standby.
    -->
    <property name="AllowStandby" type="b" access="read"/>

    <!--
        DisableUinput:

        If the daemon is configured to disable creating a uinput device to
		relay UI commands.
    -->
    <property name="DisableUinput" type="b" access="read"/>

    <!--
        Reload:

        Reload the configuration from disk
    -->
    <method name="Reload">
    </method>
  </interface>
</node>
